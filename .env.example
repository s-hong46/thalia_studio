# Copy this file to .env in the project root, then fill in the values you need.
# This public repository does not ship with any real credentials.

OPENAI_API_KEY=
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=marin
OPENAI_TTS_FORMAT=mp3
OPENAI_TTS_OUTPUT_DIR=app/static/tts
OPENAI_ASR_MODEL=gpt-4o-mini-transcribe
OPENAI_ASR_LANGUAGE=

PINECONE_API_KEY=
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
PINECONE_INDEX_PREFERENCES=talkshow-user-preferences
PINECONE_INDEX_ANTI=talkshow-anti-examples
PINECONE_INDEX_VIDEO_CLIPS=talkshow-video-clips

# Prefer DATABASE_URL for local development. SQLite keeps setup simple.
DATABASE_URL=sqlite:///artifacts/dev.db
# MYSQL_URL=mysql+pymysql://user:password@127.0.0.1:3306/Talkshow?charset=utf8mb4

VIDEO_DATASET_ROOT=movies
VIDEO_DATASET_CACHE_DIR=artifacts/video_dataset/cache
VIDEO_DATASET_PREVIEW_DIR=app/static/rehearsal/video_preview
VIDEO_DATASET_CHUNK_LEN_SEC=30.0
VIDEO_DATASET_OVERLAP_SEC=5.0
VIDEO_DATASET_TOP_K=3
VIDEO_DATASET_INITIAL_TOP_K=20

# Optional local defaults
DISABLE_VIDEO_DATASET_INGEST=1
DISABLE_REFERENCE_LLM_ENRICHMENT=0
